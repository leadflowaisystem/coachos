# Supabase — use the new publishable/secret key format
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# LLM — OpenAI-compatible endpoint (Groq by default)
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_API_KEY=
LLM_MODEL_FAST=llama-3.1-8b-instant
LLM_MODEL_SMART=llama-3.3-70b-versatile

# Razorpay — client payments & our own subscription billing
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Cal.com — booking integration
CAL_API_KEY=
CAL_WEBHOOK_SECRET=

# Inngest — optional in local dev (uses "local" key by default)
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
