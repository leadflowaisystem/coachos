# ── Core — required to boot ────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Connection pooler URL — reserved for future direct-pg tooling (migration scripts).
# The Supabase JS client does NOT use this; it pools via HTTP/PostgREST automatically.
SUPABASE_DB_POOL_URL=

# ── AI — Groq (free tier, no monthly cap) ──────────────────────
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_API_KEY=
LLM_MODEL_FAST=llama-3.1-8b-instant
LLM_MODEL_SMART=llama-3.3-70b-versatile

# ── Platform billing (Razorpay subscription) ───────────────────
PLATFORM_RAZORPAY_KEY_ID=
PLATFORM_RAZORPAY_KEY_SECRET=
PLATFORM_RAZORPAY_WEBHOOK_SECRET=
PLATFORM_PLAN_STARTER_ID=
PLATFORM_PLAN_GROWTH_ID=
PLATFORM_PLAN_PRO_ID=

# ── Per-org Razorpay (client payment collection) ───────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ── Cal.com ─────────────────────────────────────────────────────
CAL_API_KEY=
CAL_WEBHOOK_SECRET=

# ── Inngest (optional in local dev — uses "local" key by default) ─
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ── Encryption — AES-256-GCM for integration credentials ────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# ── App ──────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
ADMIN_EMAILS=

# ── Upstash Redis — free tier (10k commands/day) ─────────────────
# Sign up free at upstash.com. Required for production rate limiting + caching.
# Falls back to in-memory if not set (fine for dev and early prod).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── PWA Push Notifications (Web Push API, free) ──────────────────
# Generate keys: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:your-email@domain.com
# Also expose public key to the browser for push subscription:
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# ── Brevo SMTP — transactional email (free tier: 300/day) ────────
# Settings → SMTP & API → SMTP tab in your Brevo account
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@yourdomain.com

# ── Groq multi-key rotation (optional — comma-separated for redundancy) ──────
# GROQ_API_KEYS=gsk_key1,gsk_key2,gsk_key3
# Falls back to LLM_API_KEY if not set
